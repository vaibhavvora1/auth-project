<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>3D Registration Form</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      href="https://fonts.googleapis.com/css2?family=Oxanium:wght@300;400;600;700;800&family=Share+Tech+Mono&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "Oxanium", sans-serif;
        background: #060610;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }

      /* Static base grid */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(0, 200, 255, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 200, 255, 0.04) 1px, transparent 1px);
        background-size: 48px 48px;
        background-position: 0 0;
        z-index: 0;
      }

      /* Scrolling overlay grid — seamless loop */
      html::after {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(0, 200, 255, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 200, 255, 0.03) 1px, transparent 1px);
        background-size: 48px 48px;
        animation: gridScroll 16s linear infinite;
        z-index: 0;
        pointer-events: none;
      }
      @keyframes gridScroll {
        0% {
          background-position: 0 0;
        }
        100% {
          background-position: 0 48px;
        }
      }

      /* Ambient orbs */
      .glow-orb-1 {
        position: fixed;
        width: 500px;
        height: 500px;
        background: radial-gradient(
          circle,
          rgba(0, 180, 255, 0.13) 0%,
          transparent 70%
        );
        top: -120px;
        left: -120px;
        animation: orbFloat1 8s ease-in-out infinite;
        pointer-events: none;
        z-index: 1;
      }
      .glow-orb-2 {
        position: fixed;
        width: 400px;
        height: 400px;
        background: radial-gradient(
          circle,
          rgba(160, 0, 255, 0.1) 0%,
          transparent 70%
        );
        bottom: -80px;
        right: -80px;
        animation: orbFloat2 10s ease-in-out infinite;
        pointer-events: none;
        z-index: 1;
      }
      @keyframes orbFloat1 {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(40px, 30px) scale(1.1);
        }
      }
      @keyframes orbFloat2 {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(-30px, -40px) scale(1.08);
        }
      }

      /* Card */
      .card-3d {
        position: relative;
        z-index: 2;
        background: linear-gradient(
          145deg,
          rgba(255, 255, 255, 0.05),
          rgba(255, 255, 255, 0.01)
        );
        border: 1px solid rgba(0, 200, 255, 0.18);
        border-radius: 20px;
        box-shadow:
          0 0 0 1px rgba(0, 200, 255, 0.06),
          0 30px 80px rgba(0, 0, 0, 0.75),
          0 0 60px rgba(0, 180, 255, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(20px);
        animation: cardEntrance 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
        transition:
          transform 0.4s ease,
          box-shadow 0.4s ease;
        transform-style: preserve-3d;
      }
      .card-3d:hover {
        transform: rotateX(4deg) rotateY(-4deg) translateZ(12px) scale(1.01);
        box-shadow:
          0 0 0 1px rgba(0, 200, 255, 0.14),
          0 40px 100px rgba(0, 0, 0, 0.8),
          0 0 80px rgba(0, 180, 255, 0.1),
          inset 0 1px 0 rgba(255, 255, 255, 0.1);
      }
      @keyframes cardEntrance {
        from {
          opacity: 0;
          transform: translateY(60px) rotateX(20deg) scale(0.9);
        }
        to {
          opacity: 1;
          transform: translateY(0) rotateX(0) scale(1);
        }
      }

      /* Top glow edge */
      .card-3d::before {
        content: "";
        position: absolute;
        top: 0;
        left: 15%;
        right: 15%;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(0, 200, 255, 0.8),
          transparent
        );
        border-radius: 100%;
      }

      /* Corner accents */
      .corner {
        position: absolute;
        width: 16px;
        height: 16px;
      }
      .corner-tl {
        top: -1px;
        left: -1px;
        border-top: 2px solid #00c8ff;
        border-left: 2px solid #00c8ff;
        border-radius: 4px 0 0 0;
      }
      .corner-tr {
        top: -1px;
        right: -1px;
        border-top: 2px solid #00c8ff;
        border-right: 2px solid #00c8ff;
        border-radius: 0 4px 0 0;
      }
      .corner-bl {
        bottom: -1px;
        left: -1px;
        border-bottom: 2px solid #00c8ff;
        border-left: 2px solid #00c8ff;
        border-radius: 0 0 0 4px;
      }
      .corner-br {
        bottom: -1px;
        right: -1px;
        border-bottom: 2px solid #00c8ff;
        border-right: 2px solid #00c8ff;
        border-radius: 0 0 4px 0;
      }

      /* Badge */
      .header-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 14px;
        background: rgba(0, 200, 255, 0.08);
        border: 1px solid rgba(0, 200, 255, 0.25);
        border-radius: 20px;
        font-family: "Share Tech Mono", monospace;
        font-size: 10px;
        letter-spacing: 3px;
        color: #00c8ff;
        margin-bottom: 18px;
      }
      .badge-dot {
        width: 6px;
        height: 6px;
        background: #00c8ff;
        border-radius: 50%;
        animation: blink 2s ease-in-out infinite;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.3;
          transform: scale(0.6);
        }
      }

      /* Input wrapper stagger */
      .input-wrap {
        position: relative;
        animation: slideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      .input-wrap:nth-child(1) {
        animation-delay: 0.15s;
      }
      .input-wrap:nth-child(2) {
        animation-delay: 0.23s;
      }
      .input-wrap:nth-child(3) {
        animation-delay: 0.31s;
      }
      .input-wrap:nth-child(4) {
        animation-delay: 0.39s;
      }
      .input-wrap:nth-child(5) {
        animation-delay: 0.47s;
      }
      @keyframes slideIn {
        from {
          opacity: 0;
          transform: translateX(-18px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }

      /* Label */
      .field-label {
        font-family: "Share Tech Mono", monospace;
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(0, 200, 255, 0.55);
        margin-bottom: 7px;
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .field-label::before {
        content: "//";
        opacity: 0.4;
      }

      /* Input */
      .field-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 13px 16px 13px 44px;
        color: #e2f4ff;
        font-family: "Share Tech Mono", monospace;
        font-size: 14px;
        letter-spacing: 1px;
        outline: none;
        transition:
          border-color 0.3s,
          background 0.3s,
          box-shadow 0.3s;
        box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.3);
        -webkit-appearance: none;
      }
      .field-input::placeholder {
        color: rgba(255, 255, 255, 0.14);
      }
      .field-input:focus {
        border-color: rgba(0, 200, 255, 0.55);
        background: rgba(0, 200, 255, 0.04);
        box-shadow:
          0 0 0 3px rgba(0, 200, 255, 0.09),
          inset 0 2px 8px rgba(0, 0, 0, 0.2),
          0 0 18px rgba(0, 200, 255, 0.07);
        color: #fff;
      }

      /* Icon inside input */
      .field-icon {
        position: absolute;
        left: 14px;
        bottom: 13px;
        width: 18px;
        height: 18px;
        color: #00c8ff;
        opacity: 0.3;
        transition: opacity 0.3s;
        pointer-events: none;
      }
      .input-wrap:focus-within .field-icon {
        opacity: 0.9;
      }

      /* Scan line on focus */
      .field-line {
        position: absolute;
        bottom: 0;
        left: 10%;
        right: 10%;
        height: 1px;
        background: linear-gradient(90deg, transparent, #00c8ff, transparent);
        transform: scaleX(0);
        transition: transform 0.4s ease;
        border-radius: 1px;
      }
      .input-wrap:focus-within .field-line {
        transform: scaleX(1);
      }

      /* Divider */
      .divider {
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.07),
          transparent
        );
        margin: 22px 0;
      }

      /* Submit button */
      .btn-submit {
        width: 100%;
        padding: 15px;
        font-family: "Oxanium", sans-serif;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: #060610;
        background: linear-gradient(135deg, #00c8ff 0%, #0088cc 100%);
        border: none;
        border-radius: 10px;
        cursor: pointer;
        overflow: hidden;
        position: relative;
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease,
          background 0.25s;
        box-shadow:
          0 8px 28px rgba(0, 180, 255, 0.32),
          0 2px 8px rgba(0, 0, 0, 0.3);
        animation: slideIn 0.6s 0.56s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      .btn-submit::after {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.28),
          transparent
        );
        transition: left 0.55s ease;
      }
      .btn-submit:hover {
        transform: translateY(-3px);
        box-shadow:
          0 16px 42px rgba(0, 180, 255, 0.48),
          0 4px 12px rgba(0, 0, 0, 0.3);
        background: linear-gradient(135deg, #22d4ff 0%, #00aaff 100%);
      }
      .btn-submit:hover::after {
        left: 100%;
      }
      .btn-submit:active {
        transform: translateY(1px) scale(0.985);
        box-shadow: 0 4px 16px rgba(0, 180, 255, 0.25);
      }

      /* Login redirect link */
      .login-redirect {
        font-family: "Share Tech Mono", monospace;
        font-size: 11px;
        letter-spacing: 1px;
        color: rgba(255, 255, 255, 0.28);
        text-align: center;
        margin-top: 18px;
      }
      .login-redirect a {
        color: #00c8ff;
        text-decoration: none;
        opacity: 0.8;
        border-bottom: 1px solid rgba(0, 200, 255, 0.3);
        padding-bottom: 1px;
        transition:
          opacity 0.2s,
          border-color 0.2s,
          text-shadow 0.2s;
      }
      .login-redirect a:hover {
        opacity: 1;
        border-color: rgba(0, 200, 255, 0.9);
        text-shadow: 0 0 10px rgba(0, 200, 255, 0.6);
      }

      /* Footer */
      .footer-mono {
        font-family: "Share Tech Mono", monospace;
        font-size: 10px;
        letter-spacing: 1.5px;
        color: rgba(255, 255, 255, 0.13);
        text-align: center;
      }

      /* Password field right padding */
      .pwd-field {
        padding-right: 16px;
      }
    </style>
  </head>
  <body>
    <div class="glow-orb-1"></div>
    <div class="glow-orb-2"></div>

    <div
      class="w-full flex items-center justify-center px-4 py-10"
      style="perspective: 1000px; position: relative; z-index: 2"
    >
      <div class="card-3d w-full max-w-md p-8 md:p-10">
        <div class="corner corner-tl"></div>
        <div class="corner corner-tr"></div>
        <div class="corner corner-bl"></div>
        <div class="corner corner-br"></div>

        <!-- Header -->
        <div class="text-center mb-8">
          <div class="flex justify-center">
            <span class="header-badge">
              <span class="badge-dot"></span>
              REGISTER
            </span>
          </div>
          <h1
            class="text-3xl font-extrabold tracking-wide text-white mb-1"
            style="text-shadow: 0 0 30px rgba(0, 200, 255, 0.3)"
          >
            Create Account
          </h1>
          <p
            style="
              font-family: &quot;Share Tech Mono&quot;, monospace;
              font-size: 10px;
              letter-spacing: 3px;
              color: rgba(255, 255, 255, 0.22);
            "
          >
            INITIALIZE YOUR PROFILE
          </p>
        </div>

        <!-- Form -->
        <form
          class="flex flex-col gap-2"
          autocomplete="off"
          action="/register"
          method="post"
        >
          <!-- Full Name -->
          <div class="input-wrap">
            <label class="field-label">Full Name</label>
            <div class="relative">
              <svg
                class="field-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
                />
              </svg>
              <input
                class="field-input"
                type="text"
                name="name"
                placeholder="Enter your full name"
                required
                autocapitalize="words"
              />
              <div class="field-line"></div>
            </div>
          </div>

          <!-- Username -->
          <div class="input-wrap">
            <label class="field-label">Username</label>
            <div class="relative">
              <svg
                class="field-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z"
                />
              </svg>
              <input
                class="field-input"
                type="text"
                name="username"
                placeholder="Enter username"
                required
              />
              <div class="field-line"></div>
            </div>
          </div>

          <!-- Age -->
          <div class="input-wrap">
            <label class="field-label">Age</label>
            <div class="relative">
              <svg
                class="field-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
                />
              </svg>
              <input
                class="field-input"
                type="number"
                name="age"
                placeholder="Enter your age"
                min="1"
                max="120"
                required
              />
              <div class="field-line"></div>
            </div>
          </div>

          <!-- Email -->
          <div class="input-wrap">
            <label class="field-label">Email</label>
            <div class="relative">
              <svg
                class="field-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                />
              </svg>
              <input
                class="field-input"
                type="email"
                name="email"
                placeholder="Enter your email"
                required
              />
              <div class="field-line"></div>
            </div>
          </div>

          <!-- Password -->
          <div class="input-wrap">
            <label class="field-label">Password</label>
            <div class="relative">
              <svg
                class="field-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
                />
              </svg>
              <input
                class="field-input pwd-field"
                type="password"
                name="password"
                placeholder="Enter your password"
                required
              />
              <div class="field-line"></div>
            </div>
          </div>

          <div class="divider"></div>

          <!-- Submit -->
          <button type="submit" class="btn-submit">Initialize Account</button>
        </form>

        <!-- Login Redirect -->
        <p class="login-redirect">
          Already have an account? <a href="/login">Login here</a>
        </p>

        <p class="footer-mono mt-5">ENCRYPTED · SECURE · v2.0.1</p>
      </div>
    </div>
  </body>
</html>
