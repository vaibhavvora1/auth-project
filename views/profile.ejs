<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profile Page</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body>
    <div class="w-full min-h-screen bg-gradient-to-r from-blue-800 to-cyan-500 text-white px-4 sm:px-6 lg:px-10 py-6">
      
      <!-- Container -->
      <div class="max-w-6xl mx-auto">

        <!-- Top Bar -->
        <div class="flex justify-between items-center mb-6">
          <a href="/profile/upload" class="text-gray-200 hover:text-white font-semibold">
            Upload Profile Picture
          </a>

          <a
            href="/logout"
            class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg font-semibold"
          >
            Logout
          </a>
        </div>

        <!-- Profile Section -->
        <div class="flex flex-col sm:flex-row items-start gap-4 mb-8">
          <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full overflow-hidden border-2 border-white/30">
            <img
              src="<%= user.profilepic ? '/images/uploads/' + user.profilepic : '/images/default.png' %>"
              alt="Profile Picture"
              class="w-full h-full object-cover"
            />
          </div>

          <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold">
            <span class="text-lg sm:text-xl block">Hello,</span>
            <%= user.name %> 👋
          </h1>
        </div>

        <!-- Create Post -->
        <div class="mb-10 max-w-xl">
          <h3 class="font-bold text-xl sm:text-2xl mb-4">
            Create a Post
          </h3>

          <form action="/post" method="POST" class="space-y-4">
            <input
              type="text"
              name="title"
              placeholder="Post title"
              required
              class="w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-400 outline-none"
            />

            <textarea
              name="content"
              rows="4"
              placeholder="What's on your mind?"
              required
              class="w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-blue-400 outline-none resize-none"
            ></textarea>

            <button
              type="submit"
              class="bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg font-semibold w-full sm:w-auto"
            >
              Create Post
            </button>
          </form>
        </div>

        <!-- Posts Section -->
        <div>
          <h3 class="text-2xl sm:text-3xl font-bold text-center mb-6">
            Your Posts
          </h3>

          <!-- Empty State -->
          <% if (user.post.length === 0) { %>
            <p class="text-center text-gray-200">
              No posts yet. Start creating something 🚀
            </p>
          <% } %>

          <!-- Posts Grid -->
          <div class="flex flex-wrap gap-4 justify-center">
            
            <% [...user.post].reverse().forEach(function (post) { %>

              <div class="w-full sm:w-[48%] lg:w-[30%] bg-white/10 backdrop-blur-lg border border-white/20 p-4 rounded-xl shadow-lg">

                <h4 class="text-sm text-gray-300 mb-1">
                  @<%= user.username %>
                </h4>

                <h3 class="text-xl font-bold mb-2">
                  <%= post.title %>
                </h3>

                <p class="text-gray-200 text-sm mb-3">
                  <%= post.content %>
                </p>

                <small class="text-gray-400 text-xs">
                  <%= post.likes.length %> Likes
                </small>

                <div class="flex gap-4 mt-3 text-sm">
                  <a href="/like/<%= post._id %>" class="text-blue-300 hover:text-blue-400">
                    <%= post.likes.indexOf(user.userid) === -1 ? 'Like' : 'Unlike' %>
                  </a>

                  <a href="/edit/<%= post._id %>" class="text-gray-300 hover:text-white">
                    Edit
                  </a>
                </div>

              </div>

            <% }) %>

          </div>
        </div>

      </div>
    </div>
  </body>
</html>